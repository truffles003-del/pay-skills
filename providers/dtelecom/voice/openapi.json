    "/v1/servers/status": {
      "get": {
        "summary": "Get server availability by service type",
        "x-agentcash-auth": {
          "mode": "unprotected"
        },
        "responses": {
          "200": {
            "description": "Server status by service"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "walletAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Wallet signature auth. Sign 'METHOD\\nPATH\\nTIMESTAMP' with Ed25519 (Solana) or ECDSA (EVM). Value format: <chain>:<signature>"
      }
    }
  }
