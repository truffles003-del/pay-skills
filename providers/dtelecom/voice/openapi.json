                    "type": "string"
                  },
                  "participant_identity": {
                    "type": "string"
                  },
                  "duration_minutes": {
                    "type": "number"
                  },
                  "metadata": {
                    "type": "string"
                  },
                  "client_ip": {
                    "type": "string",
                    "description": "End user's IP for geo-routing the ws_url to the nearest SFU. Use when your server creates tokens on behalf of remote users. Falls back to X-Forwarded-For if omitted."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "WebRTC session created",
