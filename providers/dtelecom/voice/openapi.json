            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Wallet-Chain",
            "in": "header",
            "description": "solana or evm",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "solana",
                "evm"
              ]
            }
          },
          {
            "name": "X-Timestamp",
            "in": "header",
            "description": "Unix epoch seconds",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated transaction list"
          }
        },
        "security": [
          {
            "walletAuth": []
          }
        ]
      }
    },
