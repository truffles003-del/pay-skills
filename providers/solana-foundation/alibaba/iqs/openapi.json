    "/linked-retrieval/linked-retrieval-entry/v2/linkedRetrieval/commands/genericAdvancedSearch": {
      "get": {
        "description": "This topic describes how to invoke the GenericAdvancedSearch API by using the Alibaba Cloud OpenAPI software development kit (SDK) and provides a parameter guide. Compared with GenericSearch, GenericAdvancedSearch offers improved retrieval from authoritative sites, supporting up to 40 retrieved results, thereby delivering better authority and data diversity. The response fields and format of this enhanced API are consistent with those of GenericAdvancedSearch.",
        "operationId": "alibaba.iqs.GenericAdvancedSearch",
        "parameters": [
          {
            "description": "The query question.",
            "in": "query",
            "name": "query",
            "required": true,
            "schema": {
              "description": "The query question.",
              "example": "苹果手机",
              "type": "string"
            }
          },
          {
            "description": "The publication time range of web pages.",
            "in": "query",
            "name": "timeRange",
            "required": false,
            "schema": {
              "description": "The publication time range of web pages.",
              "example": "OneWeek",
              "type": "string"
            }
          },
          {
            "description": "The session ID for multi-turn interactions.",
            "in": "query",
            "name": "sessionId",
            "required": false,
            "schema": {
              "description": "The session ID for multi-turn interactions.",
              "example": "job-4065bee3-e7aa-49fc-aad2-a8e3a7fd6acd",
              "type": "string"
            }
          },
          {
            "description": "Industry. When specified, only content from sites limited to the specified industry is retrieved. Separate multiple industries with commas.",
            "in": "query",
            "name": "industry",
            "required": false,
            "schema": {
              "description": "Industry. When specified, only content from sites limited to the specified industry is retrieved. Separate multiple industries with commas.",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
