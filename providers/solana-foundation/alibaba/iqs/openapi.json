            "name": "page",
            "required": false,
            "schema": {
              "description": "Page number: starts from 1",
              "example": "1",
              "format": "int32",
              "type": "integer"
            }
          },
          {
            "description": "Number of items per page",
            "in": "query",
            "name": "pageSize",
            "required": false,
            "schema": {
