{
  "info": {
    "description": "Filtered OpenAPI description for the stateless synchronous Alibaba Cloud Image Audit proxy. The gateway serves only the allowlisted operations defined in the paired YAML manifest.",
    "title": "Alibaba Cloud Image Audit API",
    "version": "2019-12-30"
  },
  "openapi": "3.0.3",
  "paths": {
    "/scan-image": {
      "post": {
        "description": "This topic describes the syntax and examples of ScanImage for Image Content Moderation. The gateway injects Alibaba RPC Action=ScanImage and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.imageaudit.ScanImage",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "Scene": {
                    "description": "1",
                    "example": "porn",
                    "items": {
                      "description": "Specifies the application scenario for image detection. Valid values include:\n\n- porn: Intelligent pornography detection\n\n- terrorism: Detection of sensitive content and threat-related figures in images\n\n- ad: Junk content detection in images\n\n- live: Detection of inappropriate scenes in images\n\n- logo: Logo detection in images\n\n> Multiple scenarios can be detected simultaneously. For example, `scenes=[\"porn\", \"terrorism\"]` performs both pornography and terrorism-related detection on a single image, and billing applies to both scenarios.",
                      "example": "porn",
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "Task": {
                    "description": "1",
                    "items": {
                      "description": "1",
                      "properties": {
                        "DataId": {
                          "description": "Data ID. All IDs within a single request must be unique.",
                          "example": "uuid-xxxx-xxxx-1234",
                          "type": "string"
                        },
                        "ImageTimeMillisecond": {
                          "description": "The creation or edit time of the image, in milliseconds.",
                          "example": "1",
                          "format": "int64",
                          "type": "integer"
                        },
                        "ImageURL": {
                          "description": "The URL of the image to be detected. HTTP and HTTPS protocols are supported. It is recommended to use an OSS link from the China (Shanghai) region. For files stored locally or using OSS links from regions other than China (Shanghai), see [File URL Processing](~~155645~~).\n\n> If an OSS link from the China (Shanghai) region is used, the system automatically converts the OSS URL to a private network address before downloading the file. Therefore, invoking this API does not incur OSS traffic billing.",
                          "example": "http://xxx.xxx.com/xxx.jpg",
                          "type": "string"
                        },
                        "Interval": {
                          "description": "Frame capture frequency. This parameter applies only to GIF or long image detection. A GIF can be understood as an array of images, where one frame is sampled every **interval** frames for detection. Frame capturing for GIFs is performed only when this parameter is specified. Long images include both vertically and horizontally elongated images.\n\n- Vertically elongated images (height greater than 400 pixels and height-to-width ratio greater than 2.5) are split by calculating the total number of sub-images as the integer part of `height / width`.\n\n- Horizontally elongated images (width greater than 400 pixels and width-to-height ratio greater than 2.5) are split by calculating the total number of sub-images as the integer part of `width / height`.\n\n> By default, only the first frame of a GIF or long image is detected. The `interval` parameter instructs the backend to skip frames according to the specified interval during detection to reduce detection costs. It must be used together with the `maxFrames` parameter. For example, if `interval` is set to 2 and `maxFrames` is set to 100, detection is performed on every other frame, up to a maximum of 100 frames. Billing is calculated based on the actual number of frames detected.",
                          "example": "1",
                          "format": "int32",
                          "type": "integer"
                        },
                        "MaxFrames": {
                          "description": "The maximum number of frames to capture. This parameter applies only to GIF or long image detection, with a default value of 1.  \nIf `interval * maxFrames` is less than the total number of frames contained in the image, the frame capture interval is automatically adjusted to `total number of frames in the image / maxFrames` to improve overall detection effectiveness.",
                          "example": "1",
                          "format": "int32",
                          "type": "integer"
                        }
                      },
                      "required": [
                        "ImageURL"
                      ],
                      "type": "object"
                    },
                    "type": "array"
                  }
                },
                "required": [
                  "Task",
                  "Scene"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "1",
                  "properties": {
                    "Data": {
                      "description": "The content of the returned result data.",
                      "properties": {
                        "Results": {
                          "description": "Image detection results.",
                          "items": {
                            "description": "1",
                            "properties": {
                              "DataId": {
                                "description": "The data ID.",
                                "example": "uuid-xxxx-xxx-1234",
                                "type": "string"
                              },
                              "ImageURL": {
                                "description": "The image URL.",
                                "example": "http://xxx.xxx.xxx/xxx.jpg",
                                "type": "string"
                              },
                              "SubResults": {
                                "description": "Detection results for a single image.",
                                "items": {
                                  "description": "1",
                                  "properties": {
                                    "Frames": {
                                      "description": "If the image to be detected is truncated due to excessive length, this parameter returns a temporary access URL for each frame of the truncated image for your reference.",
                                      "items": {
                                        "description": "1",
                                        "properties": {
                                          "Rate": {
                                            "description": "The probability that the result belongs to this category, with a value range of 0 to 100. A higher value indicates a greater likelihood of belonging to this category.",
                                            "example": "89.85",
                                            "format": "float",
                                            "type": "number"
                                          },
                                          "URL": {
                                            "description": "A temporary access URL for the truncated image. The URL has a validity period of 5 minutes.",
                                            "example": "http://xxx.xxx.com/xxx-0.jpg",
                                            "type": "string"
                                          }
                                        },
                                        "type": "object"
                                      },
                                      "type": "array"
                                    },
                                    "HintWordsInfoList": {
                                      "description": "When the image contains advertisements, returns the threat-related sensitive words in the advertisement text that were hit. The format is an array.\n\n> Applies only to the ad scenario. Example value: `\"hintWordsInfo\":[{\"context\":\"sensitive word\"}]`.",
                                      "items": {
                                        "description": "1",
                                        "properties": {
                                          "Context": {
                                            "description": "The content of threat-related keywords detected in the text within the image.",
                                            "example": "abc",
                                            "type": "string"
                                          }
                                        },
                                        "type": "object"
                                      },
                                      "type": "array"
                                    },
                                    "Label": {
                                      "description": "The categorization of the detection result, corresponding to a specific scenario. For valid values, see the mapping between scene and label.",
                                      "example": "normal",
                                      "type": "string"
                                    },
                                    "LogoDataList": {
                                      "description": "When the image contains a logo, the detected logo information is returned.\n\n> Applies only to the logo scenario.",
                                      "items": {
                                        "description": "1",
                                        "properties": {
                                          "Height": {
                                            "description": "The height of the Logo area.",
                                            "example": "106",
                                            "format": "float",
                                            "type": "number"
                                          },
                                          "Name": {
                                            "description": "The Name of the detected Logo.",
                                            "example": "abc",
                                            "type": "string"
                                          },
                                          "Type": {
                                            "description": "The type of the detected logo. The value is TV (TV station logo).",
                                            "example": "TV",
                                            "type": "string"
                                          },
                                          "Width": {
                                            "description": "The width of the Logo area.",
                                            "example": "106",
                                            "format": "float",
                                            "type": "number"
                                          },
                                          "X": {
                                            "description": "The distance from the top-left corner of the Logo area to the y-axis, with the top-left corner of the Image as the coordinate origin.",
                                            "example": "140",
                                            "format": "float",
                                            "type": "number"
                                          },
                                          "Y": {
                                            "description": "The distance from the top-left corner of the Logo area to the x-axis, with the top-left corner of the Image as the coordinate origin.",
                                            "example": "68",
                                            "format": "float",
                                            "type": "number"
                                          }
                                        },
                                        "type": "object"
                                      },
                                      "type": "array"
                                    },
                                    "OCRDataList": {
                                      "description": "1",
                                      "items": {
                                        "description": "Complete text information detected in the image.",
                                        "example": "abc",
                                        "type": "string"
                                      },
                                      "type": "array"
                                    },
                                    "ProgramCodeDataList": {
                                      "description": "When the image contains a miniapp code, the position information of the miniapp code is returned.\n\n> Applies only to the qrcode scenario, and you have contacted us via DingTalk group (23109592) to enable miniapp code detection.",
                                      "items": {
                                        "description": "1",
                                        "properties": {
                                          "Height": {
                                            "description": "The height of the miniapp code area.",
                                            "example": "413.0",
                                            "format": "float",
                                            "type": "number"
                                          },
                                          "Width": {
                                            "description": "The width of the miniapp code area.",
                                            "example": "402.0",
                                            "format": "float",
                                            "type": "number"
                                          },
                                          "X": {
                                            "description": "The distance from the top-left corner of the miniapp code area to the y-axis, with the top-left corner of the image as the coordinate origin.",
                                            "example": "11.0",
                                            "format": "float",
                                            "type": "number"
                                          },
                                          "Y": {
                                            "description": "The distance from the top-left corner of the miniapp code area to the x-axis, with the top-left corner of the image as the coordinate origin.",
                                            "example": "0.0",
                                            "format": "float",
                                            "type": "number"
                                          }
                                        },
                                        "type": "object"
                                      },
                                      "type": "array"
                                    },
                                    "Rate": {
                                      "description": "Probability that the result belongs to this category, ranging from 0 to 100. A higher value indicates a greater likelihood of belonging to this category.",
                                      "example": "99.91",
                                      "format": "float",
                                      "type": "number"
                                    },
                                    "Scene": {
                                      "description": "The Image Detection scenario, corresponding to the scenario (scenes) in the Request.",
                                      "example": "ad",
                                      "type": "string"
                                    },
                                    "SfaceDataList": {
                                      "description": "When the image contains terrorism-related sensitive information, the detected sensitive information is returned.\n\n> This parameter applies only to the terrorism and sface scenarios. For details about this parameter in the sface scenario, see Sensitive Face Detection.",
                                      "items": {
                                        "description": "1",
                                        "properties": {
                                          "Faces": {
                                            "description": "The detected face information.",
                                            "items": {
                                              "description": "1",
                                              "properties": {
                                                "Id": {
                                                  "description": "Face ID.",
                                                  "example": "AliFace_0001234",
                                                  "type": "string"
                                                },
                                                "Name": {
                                                  "description": "Name of the similar person.",
                                                  "example": "abc",
                                                  "type": "string"
                                                },
                                                "Rate": {
                                                  "description": "The similarity probability.",
                                                  "example": "91.54",
                                                  "format": "float",
                                                  "type": "number"
                                                }
                                              },
                                              "type": "object"
                                            },
                                            "type": "array"
                                          },
                                          "Height": {
                                            "description": "The height of the face area.",
                                            "example": "131",
                                            "format": "float",
                                            "type": "number"
                                          },
                                          "Width": {
                                            "description": "The width of the face area.",
                                            "example": "97",
                                            "format": "float",
                                            "type": "number"
                                          },
                                          "X": {
                                            "description": "With the top-left corner of the image as the coordinate origin, this value represents the distance from the top-left corner of the face area to the y-axis.",
                                            "example": "49",
                                            "format": "float",
                                            "type": "number"
                                          },
                                          "Y": {
                                            "description": "The distance from the top-left corner of the face area to the x-axis, with the top-left corner of the Image as the coordinate origin.",
                                            "example": "39",
                                            "format": "float",
                                            "type": "number"
                                          }
                                        },
                                        "type": "object"
                                      },
                                      "type": "array"
                                    },
                                    "Suggestion": {
                                      "description": "The operation recommended for you to execute.\n\n- pass: The image is normal and requires no further action, or the target object was not detected.\n\n- review: The detection result is uncertain and requires manual review, or the target object was not detected.\n\n- block: The image violates policies, and you are advised to execute further actions (such as directly deleting it or applying restrictions).",
                                      "example": "block",
                                      "type": "string"
                                    }
                                  },
                                  "type": "object"
                                },
                                "type": "array"
                              },
                              "TaskId": {
                                "description": "The job ID.",
                                "example": "img4wlJcb7p4wH4lAP3111111-123456",
                                "type": "string"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "RequestId": {
                      "description": "The request ID.",
                      "example": "69B41AE8-1234-1234-1234-12D395695D2D",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Image Content Moderation"
      }
    },
    "/scan-text": {
      "post": {
        "description": "This topic describes the syntax and examples of the ScanText operation in Content Moderation. The gateway injects Alibaba RPC Action=ScanText and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.imageaudit.ScanText",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "Labels": {
                    "description": "1",
                    "items": {
                      "properties": {
                        "Label": {
                          "description": "Specify the application scenario for text detection. Valid values include:\n\n- spam: detects text spam content\n\n- politics: detects politically sensitive text content\n\n- abuse: detects abusive text content\n\n- terrorism: detects terrorist-related text content\n\n- porn: detects pornographic text content\n\n- flood: detects flooding (excessive repetitive) text content\n\n- contraband: detects prohibited text content\n\n- ad: detects advertising text content",
                          "example": "ad",
                          "type": "string"
                        }
                      },
                      "required": [
                        "Label"
                      ],
                      "type": "object"
                    },
                    "type": "array"
                  },
                  "Tasks": {
                    "description": "1",
                    "items": {
                      "properties": {
                        "Content": {
                          "description": "Specifies the object to be detected. Each element in the JSON array is a struct representing a text detection job.\n\n> - N tasks will be billed as N invocations.\n- For questions about algorithm detection performance, join the Alibaba Cloud Visual Intelligence API support DingTalk group (23109592) to contact us.",
                          "example": "维修管道，联系weixin",
                          "type": "string"
                        }
                      },
                      "required": [
                        "Content"
                      ],
                      "type": "object"
                    },
                    "type": "array"
                  }
                },
                "required": [
                  "Tasks",
                  "Labels"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Data": {
                      "description": "The content of the returned result data.",
                      "properties": {
                        "Elements": {
                          "description": "Sub-elements of the detection results.",
                          "items": {
                            "properties": {
                              "Results": {
                                "description": "Detection results. If this field is empty, it indicates that the system identified a hit under another label. You should expand the label and resend the request.",
                                "items": {
                                  "properties": {
                                    "Details": {
                                      "description": "Detection results for the content.",
                                      "items": {
                                        "properties": {
                                          "Contexts": {
                                            "description": "Information that hits this threat.",
                                            "items": {
                                              "properties": {
                                                "Context": {
                                                  "description": "The risk content in the detected text that was hit.",
                                                  "example": "联系weixin",
                                                  "type": "string"
                                                }
                                              },
                                              "type": "object"
                                            },
                                            "type": "array"
                                          },
                                          "Label": {
                                            "description": "Categorization of the detected threat content.",
                                            "example": "ad",
                                            "type": "string"
                                          }
                                        },
                                        "type": "object"
                                      },
                                      "type": "array"
                                    },
                                    "Label": {
                                      "description": "The categorization of the detection result.",
                                      "example": "ad",
                                      "type": "string"
                                    },
                                    "Rate": {
                                      "description": "The probability that the result belongs to this category, ranging from `[0.00–100.00]`. A higher value indicates a greater likelihood of belonging to this category.",
                                      "example": "99.91",
                                      "format": "float",
                                      "type": "number"
                                    },
                                    "Suggestion": {
                                      "description": "The operation you are advised to execute. Valid values:\n\n- pass: The content is normal.\n\n- review: Manual review is required.\n\n- block: The content violates policies and can be directly deleted or restricted.",
                                      "example": "block",
                                      "type": "string"
                                    }
                                  },
                                  "type": "object"
                                },
                                "type": "array"
                              },
                              "TaskId": {
                                "description": "Job ID.",
                                "example": "txt6Vh5Fv0DAFy5hgdVRt3pqf-1s82jj",
                                "type": "string"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "RequestId": {
                      "description": "Request ID.",
                      "example": "C7CD87E3-57A5-4E2F-8A44-809F3554692C",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Text Content Moderation"
      }
    }
  },
  "servers": [
    {
      "url": "https://imageaudit.alibaba.gateway-402.com"
    }
  ]
}
