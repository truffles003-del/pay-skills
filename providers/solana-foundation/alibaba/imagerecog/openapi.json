{
  "info": {
    "description": "Filtered OpenAPI description for the stateless synchronous Alibaba Cloud Image Recognition proxy. The gateway serves only the allowlisted operations defined in the paired YAML manifest.",
    "title": "Alibaba Cloud Image Recognition API",
    "version": "2019-09-30"
  },
  "openapi": "3.0.3",
  "paths": {
    "/classifying-rubbish": {
      "post": {
        "description": "This document describes the syntax and examples for ClassifyingRubbish, a garbage classification recognition feature. The gateway injects Alibaba RPC Action=ClassifyingRubbish and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.imagerecog.ClassifyingRubbish",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "ImageURL": {
                    "description": "The image URL. We recommend using an OSS link in the China (Shanghai) region. For files stored locally or using OSS links in other regions, see [File URL Processing](~~155645~~).",
                    "example": "http://viapi-test.oss-cn-shanghai.aliyuncs.com/viapi-3.0domepic/imagerecog/ClassifyingRubbish/ClassifyingRubbish6.jpg",
                    "type": "string"
                  }
                },
                "required": [
                  "ImageURL"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Data": {
                      "description": "The returned result data content.",
                      "properties": {
                        "Elements": {
                          "description": "Outputs garbage detection results.",
                          "items": {
                            "properties": {
                              "Category": {
                                "description": "Garbage category. Includes recyclable waste, dry waste, wet waste, and hazardous waste.",
                                "example": "可回收垃圾",
                                "type": "string"
                              },
                              "CategoryScore": {
                                "description": "Confidence level of the detected garbage category.",
                                "example": "0.9406",
                                "format": "float",
                                "type": "number"
                              },
                              "Rubbish": {
                                "description": "The specific item name.",
                                "example": "纸板箱",
                                "type": "string"
                              },
                              "RubbishScore": {
                                "description": "Confidence level of the item name.",
                                "example": "0.9406",
                                "format": "float",
                                "type": "number"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        },
                        "Sensitive": {
                          "description": "Whether the image contains Sensitive Information.\n\n- true: Sensitive Information is present, and specific garbage classification information will not be returned.\n\n- false: No Sensitive Information is present.",
                          "example": "false",
                          "type": "boolean"
                        }
                      },
                      "type": "object"
                    },
                    "RequestId": {
                      "description": "Request ID.",
                      "example": "1619647E-92ED-5641-A1D9-F05C33FD294A",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Garbage Classification Detection"
      }
    },
    "/detect-image-elements": {
      "post": {
        "description": "This topic describes the syntax and examples of the DetectImageElements operation for element detection. The gateway injects Alibaba RPC Action=DetectImageElements and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.imagerecog.DetectImageElements",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "Url": {
                    "description": "The image URL. We recommend using an OSS Link in the China (Shanghai) Region. If your file is stored locally or in an OSS bucket outside the China (Shanghai) Region, see [File URL Processing](~~155645~~).",
                    "example": "http://viapi-test.oss-cn-shanghai.aliyuncs.com/viapi-3.0domepic/imagerecog/DetectImageElements/DetectImageElements5.jpg",
                    "type": "string"
                  }
                },
                "required": [
                  "Url"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Data": {
                      "description": "The content of the returned result data.",
                      "properties": {
                        "Elements": {
                          "description": "List of elements.",
                          "items": {
                            "properties": {
                              "Height": {
                                "description": "Height of the element.",
                                "example": "354",
                                "format": "int32",
                                "type": "integer"
                              },
                              "Score": {
                                "description": "Confidence level, with a value range of `[0.0, 1.0]`.",
                                "example": "0.997097373008728",
                                "format": "float",
                                "type": "number"
                              },
                              "Type": {
                                "description": "Element Type. Includes:  \nUnType (undefined type), AllType (all types), RootType (root type), Synthesis (composite element graph), Embedded (all nested types), Format (element format), MajorObject (entity), Character (text content), Identifier (identity), Background (background), Decoration (decoration), MajorHuman (human model), MajorAuction (Product), MajorThing (object), MajorOther (other entity), CharMain (main text), CharSub (sub-text), CharAction (call-to-action text), CharContent (content text), CharNumber (numeric text), CharOther (other text), IdentLogo (logo identity), IdentLight (highlighted identity), IdentCode (code identity), IdentOther (other identity), BackBitmap (bitmap background), BackVector (Vector Graphic background), BackOther (other background), DecoTile (tile decoration), DecoRegion (area decoration), DecoPieces (fragmentation decoration), DecoEdge (edge decoration), DecoLine (linear decoration), DecoBox (box-shaped decoration), DecoChar (call-to-action text decoration), DecoOther (other decoration), SynthMajor (entity group), SynthChar (text group), SynthIdent (identity group), SynthBack (background group), SynthDeco (decoration group), SynthOther (other group), EmbedSvg (svg nested format), EmbedJson (JSON nested format), EmbedHtml (html nested format).",
                                "example": "majorhuman",
                                "type": "string"
                              },
                              "Width": {
                                "description": "Element width.",
                                "example": "285",
                                "format": "int32",
                                "type": "integer"
                              },
                              "X": {
                                "description": "X-axis coordinate of the top-left corner of the element.",
                                "example": "287",
                                "format": "int32",
                                "type": "integer"
                              },
                              "Y": {
                                "description": "Y-axis coordinate of the top-left corner of the element.",
                                "example": "78",
                                "format": "int32",
                                "type": "integer"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "RequestId": {
                      "description": "Request ID.",
                      "example": "7EE82437-AEC4-5AAF-819F-AB28C23EE0FC",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Element Detection"
      }
    },
    "/evaluate-certificate-quality": {
      "post": {
        "description": "This topic describes the syntax and examples of the EvaluateCertificateQuality API for certificate photo quality review. The gateway injects Alibaba RPC Action=EvaluateCertificateQuality and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.imagerecog.EvaluateCertificateQuality",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "ImageURL": {
                    "description": "The image URL. We recommend using an OSS link in the China (Shanghai) region. For files stored locally or in an OSS bucket outside the China (Shanghai) region, see [File URL Processing](~~155645~~).",
                    "example": "https://viapi-doc.oss-cn-shanghai.aliyuncs.com/imagerecog/xxxxx.jpg",
                    "type": "string"
                  },
                  "Type": {
                    "description": "The type of certificate.\n\n- IDCard: Identity card.\n- BusinessLicense: Electronic business license.",
                    "example": "BusinessLicense",
                    "type": "string"
                  }
                },
                "required": [
                  "ImageURL",
                  "Type"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Data": {
                      "description": "The content of the returned result data.",
                      "properties": {
                        "Elements": {
                          "description": "The list of detected quality issues in the output.",
                          "items": {
                            "properties": {
                              "Pass": {
                                "description": "Indicates whether the check passed.\n\n- true: Passed the check.\n- false: Failed the check.\n- verify: Unable to verify certificate quality; manual confirmation is required.\n- ERROR: The module algorithm inference failed.",
                                "example": "false",
                                "type": "string"
                              },
                              "Score": {
                                "description": "The quality issue score. A higher score indicates a more critical issue. The value is an integer between 0 and 100.\n\n- When the system cannot provide a score, the output is `score`.\n- When the **Pass** field is `ERROR`, the output is `null`.",
                                "example": "0.06514739990234375",
                                "type": "string"
                              },
                              "Value": {
                                "description": "The type of issue.\n\n- lackoffront: Missing front-side photo.\n- copy: Photocopy.\n- imageincomplete: Incomplete certificate image.\n- nationalemblemincomplete: Incomplete national emblem on the business license.\n- lackofseal: Missing seal.\n- electronic: Sourced from an electronic document.\n- reflection: Glare or reflection.\n\n> - If the request parameter **Type** is IDCard, the value `lackofseal` (missing seal) does not apply.\n- If the request parameter **Type** is BusinessLicense, the value `lackoffront` (missing front-side photo) does not apply.",
                                "example": "lackoffront",
                                "type": "string"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "RequestId": {
                      "description": "The request ID.",
                      "example": "656318DC-3856-43E3-9147-859532721AD6",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Certificate Photo Quality Review"
      }
    },
    "/recognize-food": {
      "post": {
        "description": "This topic describes the syntax and examples of the RecognizeFood API. The gateway injects Alibaba RPC Action=RecognizeFood and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.imagerecog.RecognizeFood",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "ImageURL": {
                    "description": "Image URL. We recommend using an OSS link in the China (Shanghai) Region. If your file is stored locally or in an OSS bucket outside the China (Shanghai) Region, see [File URL Processing](~~155645~~).",
                    "example": "http://viapi-test.oss-cn-shanghai.aliyuncs.com/viapi-3.0domepic/imagerecog/RecognizeFood/RecognizeFood5.jpg",
                    "type": "string"
                  }
                },
                "required": [
                  "ImageURL"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "Schema of Response",
                  "properties": {
                    "Data": {
                      "description": "The returned result data.",
                      "properties": {
                        "TopFives": {
                          "description": "The top five most likely categories detected, sorted in descending order by confidence level.  \n\n> Fewer than five results may be returned; up to five are displayed.",
                          "items": {
                            "description": "1",
                            "properties": {
                              "Calorie": {
                                "description": "Calorie value per 100 grams. For example, if the detected dish is \"Three Mushroom Soup\" with a value of 208, it means that 100 grams of Three Mushroom Soup contains 208 kilocalories.\n\n> Some dishes are rare and do not have a standardized calorie value; therefore, they are annotated as `UNKNOWN`, indicating that the value is unknown.",
                                "example": "208",
                                "type": "string"
                              },
                              "Category": {
                                "description": "Category.",
                                "example": "清蒸鲈鱼",
                                "type": "string"
                              },
                              "Score": {
                                "description": "Confidence level for detecting the dish category, ranging from 0 to 1.",
                                "example": "0.2083740234375",
                                "format": "float",
                                "type": "number"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "RequestId": {
                      "description": "The ID of the request.",
                      "example": "4C2369C5-54E0-4B9F-8ACB-80C4F50AD2DB",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Dish Recognition"
      }
    },
