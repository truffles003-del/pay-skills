    "/tagging-ad-image": {
      "post": {
        "description": "This topic describes the syntax and examples of the Ad Material Analysis TaggingAdImage API. The gateway injects Alibaba RPC Action=TaggingAdImage and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.imagerecog.TaggingAdImage",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "ImageURL": {
                    "description": "The image URL. We recommend using an OSS link in the China (Shanghai) region. For files stored locally or via OSS links in other regions, see [File URL Processing](~~155645~~).",
                    "example": "https://viapi-demo.oss-cn-shanghai.aliyuncs.com/viapi-demo/images/DetectImageElements/xxxx.png",
                    "type": "string"
                  }
                },
                "required": [
                  "ImageURL"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "Schema of Response",
                  "properties": {
                    "Data": {
                      "description": "The content of the returned result data.  \nThis data is obtained only after the asynchronous task execution succeeds, by invoking the [GetAsyncJobResult](~~607824~~) API and performing JSON deserialization on its Result field.",
                      "properties": {
                        "TagInfo": {
                          "additionalProperties": true,
                          "description": "Tag. Currently, only \"scene\" (scenario) and \"human\" are output. For specific values, see the table below titled \"Parameter Guide for TagInfo Field\".",
                          "type": "object"
                        }
                      },
                      "type": "object"
                    },
