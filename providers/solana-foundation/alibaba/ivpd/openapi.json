    "/recolor-image": {
      "post": {
        "description": "Automatically or based on a specified color palette, transform the colors of the input image while ensuring that visual hot spot areas avoid unnatural recoloring. The gateway injects Alibaba RPC Action=RecolorImage and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.ivpd.RecolorImage",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "ColorCount": {
                    "default": "1",
                    "description": "Number of extended colors. Valid values: [1, 8]. Default value: 1.",
                    "example": "3",
                    "format": "int32",
                    "type": "integer"
                  },
                  "ColorTemplate": {
                    "items": {
                      "properties": {
                        "Color": {
                          "description": "Color palette expansion. A list of primary colors for the top, with color values defined in ARGB format, such as 0A0B0C. The array size must be within the range [1, 7].",
                          "example": "0A0B0C",
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "type": "array"
                  },
                  "Mode": {
                    "description": "Recoloring pattern. Default value: AUTO. Valid values: [AUTO: automatic recoloring, TEMPLATE: palette-based recoloring, REF_PIC: reference-image-based recoloring].",
                    "example": "AUTO",
                    "type": "string"
                  },
                  "RefUrl": {
                    "description": "For reference-image-based recoloring, the URL of the reference image.",
                    "example": "http://vigen-invi-cdn.alibaba.com/aliyun-doc/pop/images/recolor-refurl-src.png",
                    "type": "string"
                  },
                  "Url": {
                    "description": "URL of the source image. The URL must be publicly accessible over the public network and can be up to 8 KB in length.",
                    "example": "http://vigen-invi-cdn.alibaba.com/aliyun-doc/pop/images/recolor-1-src.png",
                    "type": "string"
                  }
                },
                "required": [
                  "Url",
                  "Mode"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "description": "Status code",
                      "example": "0",
                      "type": "string"
                    },
                    "Data": {
                      "description": "Response data. For specific fields, view the structure definition.",
                      "properties": {
                        "ImageList": {
                          "items": {
                            "description": "List of URLs of recolored images generated.",
                            "example": "http://a.b.c/3.png",
                            "type": "string"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "Message": {
                      "example": "Success",
                      "type": "string"
                    },
                    "RequestId": {
