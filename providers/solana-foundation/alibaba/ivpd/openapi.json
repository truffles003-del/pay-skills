                            "type": "object"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "Message": {
                      "description": "Error message. When the code is not \"0\", refer to this field for specific error details.",
                      "example": "Success",
                      "type": "string"
                    },
                    "RequestId": {
                      "description": "Request ID, automatically generated by Alibaba Cloud system.",
                      "example": "7308917D-9E1B-4F11-8A79-0F140270E672",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
