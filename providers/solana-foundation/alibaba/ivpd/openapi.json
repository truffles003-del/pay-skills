  },
  "openapi": "3.0.3",
  "paths": {
    "/change-image-size": {
      "post": {
        "description": "Intelligently adjust image dimensions, supporting multiple schemes such as automatic clipping and completion. The gateway injects Alibaba RPC Action=ChangeImageSize and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.ivpd.ChangeImageSize",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "Height": {
                    "description": "Target height, in pixels. Value range: [10, 5000].",
                    "example": "1080",
                    "format": "int32",
                    "type": "integer"
                  },
                  "Url": {
                    "description": "URL of the original image. The URL must be publicly accessible over the public network and can be up to 8 KB in length.",
                    "example": "http://a.b.cn/1.jpg",
                    "type": "string"
                  },
                  "Width": {
                    "description": "Target width, in pixels. Value range: [10, 5000].",
                    "example": "1920",
                    "format": "int32",
                    "type": "integer"
                  }
                },
                "required": [
                  "Width",
                  "Height",
                  "Url"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "description": "Status code",
                      "example": "0",
                      "type": "string"
                    },
                    "Data": {
                      "description": "Response data. For specific fields, see the structure definition.",
                      "properties": {
                        "Url": {
                          "description": "Image URL. This is the address of the output image after size transformation. Note: <font color=red>the validity period is 72 hours</font>.",
                          "example": "http://a.b.c/2.jpg",
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "Message": {
                      "description": "Error message. When the code is not \"0\", view this field for specific error details.",
                      "example": "success",
                      "type": "string"
                    },
                    "RequestId": {
                      "description": "Request ID, automatically generated by the Alibaba Cloud system.",
                      "example": "7308917D-9E1B-4F11-8A79-0F140270E672",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Resize Image"
      }
    },
