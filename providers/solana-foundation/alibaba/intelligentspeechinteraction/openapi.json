{
  "components": {
    "parameters": {
      "AsrCustomizationId": {
        "description": "Optional custom language model ID configured in the Alibaba ISI console.",
        "in": "query",
        "name": "customization_id",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "AsrFormat": {
        "description": "Audio encoding format for the uploaded speech.",
        "in": "query",
        "name": "format",
        "required": true,
        "schema": {
          "enum": [
            "pcm",
            "wav",
            "opus"
          ],
          "type": "string"
        }
      },
      "AsrSampleRate": {
        "description": "Audio sample rate in Hz.",
        "in": "query",
        "name": "sample_rate",
        "required": true,
        "schema": {
          "enum": [
            8000,
            16000
          ],
          "type": "integer"
        }
      },
      "AsrVocabularyId": {
        "description": "Optional hotword vocabulary ID configured in the Alibaba ISI console.",
        "in": "query",
        "name": "vocabulary_id",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "EnableInverseTextNormalization": {
        "description": "Whether the recognizer normalizes spoken forms such as numerals.",
        "in": "query",
        "name": "enable_inverse_text_normalization",
        "required": false,
        "schema": {
          "default": true,
          "type": "boolean"
        }
      },
      "EnablePunctuationPrediction": {
        "description": "Whether the recognizer adds punctuation marks to the output text.",
        "in": "query",
        "name": "enable_punctuation_prediction",
        "required": false,
        "schema": {
          "default": true,
          "type": "boolean"
        }
      },
      "EnableVoiceDetection": {
        "description": "Whether the recognizer performs simple voice activity detection.",
        "in": "query",
        "name": "enable_voice_detection",
        "required": false,
        "schema": {
          "default": false,
          "type": "boolean"
        }
      },
      "TtsFormat": {
        "description": "Desired audio output format.",
        "in": "query",
        "name": "format",
        "required": false,
        "schema": {
          "default": "mp3",
          "enum": [
            "mp3",
            "wav",
            "pcm"
          ],
          "type": "string"
        }
      },
      "TtsPitchRate": {
        "description": "Relative pitch adjustment.",
        "in": "query",
        "name": "pitch_rate",
        "required": false,
        "schema": {
          "default": 0,
          "maximum": 500,
          "minimum": -500,
          "type": "integer"
        }
      },
      "TtsSampleRate": {
        "description": "Output sample rate in Hz.",
        "in": "query",
        "name": "sample_rate",
        "required": false,
        "schema": {
          "default": 16000,
          "enum": [
            8000,
            16000
          ],
          "type": "integer"
        }
      },
      "TtsSpeechRate": {
        "description": "Relative speech speed adjustment.",
        "in": "query",
        "name": "speech_rate",
        "required": false,
        "schema": {
          "default": 0,
          "maximum": 500,
          "minimum": -500,
          "type": "integer"
        }
      },
      "TtsText": {
        "description": "Input text to synthesize. Alibaba documents a 300-character maximum per request.",
        "in": "query",
        "name": "text",
        "required": true,
        "schema": {
          "maxLength": 300,
          "type": "string"
        }
      },
      "TtsVoice": {
        "description": "Alibaba ISI voice name. The available voice list depends on the region and project configuration.",
        "in": "query",
        "name": "voice",
        "required": false,
        "schema": {
          "default": "xiaoyun",
          "type": "string"
        }
      },
      "TtsVolume": {
        "description": "Output volume.",
        "in": "query",
        "name": "volume",
        "required": false,
        "schema": {
          "default": 50,
          "maximum": 100,
          "minimum": 0,
          "type": "integer"
        }
      }
    },
    "schemas": {
      "AsrResponse": {
        "properties": {
          "finish": {
            "type": "integer"
          },
          "request_id": {
            "type": "string"
          },
          "result": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "task_id": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "IsiErrorResponse": {
        "properties": {
          "message": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "task_id": {
            "type": "string"
          }
        },
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Filtered OpenAPI description for the Intelligent Speech Interaction proxy. This proxy currently exposes short sentence recognition and GET-based speech synthesis through the Singapore REST endpoints while the gateway manages token minting and appkey injection.",
    "title": "Alibaba Cloud Intelligent Speech Interaction REST API",
    "version": "v1"
  },
  "openapi": "3.0.3",
  "paths": {
    "/stream/v1/asr": {
      "post": {
        "description": "Upload up to 60 seconds of audio to the Intelligent Speech Interaction short sentence recognition REST API. The gateway injects the Alibaba appkey and access token before forwarding the request upstream.",
        "operationId": "alibaba.intelligentSpeechInteraction.recognizeShortSpeech",
        "parameters": [
          {
            "$ref": "#/components/parameters/AsrFormat"
          },
          {
            "$ref": "#/components/parameters/AsrSampleRate"
          },
          {
            "$ref": "#/components/parameters/AsrVocabularyId"
          },
          {
            "$ref": "#/components/parameters/AsrCustomizationId"
          },
          {
            "$ref": "#/components/parameters/EnablePunctuationPrediction"
          },
          {
            "$ref": "#/components/parameters/EnableInverseTextNormalization"
          },
          {
            "$ref": "#/components/parameters/EnableVoiceDetection"
          }
        ],
        "requestBody": {
          "content": {
            "application/octet-stream": {
              "schema": {
                "format": "binary",
                "type": "string"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsrResponse"
                }
              }
            },
            "description": "Recognition result."
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IsiErrorResponse"
                }
              }
            },
            "description": "Recognition error response."
          }
        },
        "summary": "Recognize a short audio clip",
        "tags": [
          "speech.recognition"
        ]
      }
    },
    "/stream/v1/tts": {
      "get": {
        "description": "Synthesize speech with the Intelligent Speech Interaction REST text-to-speech API. The gateway injects the Alibaba appkey and access token before forwarding the request upstream.",
        "operationId": "alibaba.intelligentSpeechInteraction.synthesizeSpeech",
        "parameters": [
          {
            "$ref": "#/components/parameters/TtsText"
          },
          {
            "$ref": "#/components/parameters/TtsFormat"
          },
          {
            "$ref": "#/components/parameters/TtsSampleRate"
          },
          {
            "$ref": "#/components/parameters/TtsVoice"
          },
          {
            "$ref": "#/components/parameters/TtsVolume"
          },
          {
            "$ref": "#/components/parameters/TtsSpeechRate"
          },
          {
            "$ref": "#/components/parameters/TtsPitchRate"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/octet-stream": {
                "schema": {
                  "format": "binary",
                  "type": "string"
                }
              },
              "audio/mpeg": {
                "schema": {
                  "format": "binary",
                  "type": "string"
                }
              },
              "audio/wav": {
                "schema": {
                  "format": "binary",
                  "type": "string"
                }
              }
            },
            "description": "Synthesized speech audio."
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IsiErrorResponse"
                }
              }
            },
            "description": "Synthesis error response."
          }
        },
        "summary": "Synthesize speech from short text",
        "tags": [
          "speech.synthesis"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "https://intelligentspeechinteraction.alibaba.gateway-402.com"
    }
  ],
  "tags": [
    {
      "name": "speech.recognition"
    },
    {
      "name": "speech.synthesis"
    }
  ]
}
