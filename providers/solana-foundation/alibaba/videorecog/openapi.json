{
  "info": {
    "description": "Filtered OpenAPI description for the stateless synchronous Alibaba Cloud Video Recognition proxy. The gateway serves only the allowlisted operations defined in the paired YAML manifest.",
    "title": "Alibaba Cloud Video Recognition API",
    "version": "2020-03-20"
  },
  "openapi": "3.0.3",
  "paths": {
    "/detect-video-shot": {
      "post": {
        "description": "Shot parsing splits the input video by shot and returns the split points. The gateway injects Alibaba RPC Action=DetectVideoShot and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.videorecog.DetectVideoShot",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "VideoUrl": {
                    "description": "The video URL. We recommend using an OSS link in the China (Shanghai) region. For files stored locally or via an OSS link in a region other than China (Shanghai), see [File URL processing](~~155645~~).",
                    "example": "http://viapi-test.oss-cn-shanghai.aliyuncs.com/viapi-3.0domepic/videorecog/DetectVideoShot/DetectVideoShot2.mp4",
                    "type": "string"
                  }
                },
                "required": [
                  "VideoUrl"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Data": {
                      "description": "The content of the returned result data.  \nThis data is obtained after the asynchronous task execution succeeds by invoking the [GetAsyncJobResult](~~607824~~) API and performing JSON deserialization on its Result field.",
                      "properties": {
                        "ShotFrameIds": {
                          "description": "1",
                          "items": {
                            "description": "Parsed result: frame numbers of segmentation points.",
                            "example": "[0, 109, 185, 251, 341, 393, 468, 629, 715, 762, 1272, 1304, 1331, 1351, 1379, 1414, 1431, 1456, 1504, 1709, 1838, 1893, 1975, 2239, 2364, 2425, 2469, 2532, 2607, 2665, 2737, 2864, 2944, 2979, 2995]",
                            "format": "int32",
                            "type": "integer"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "Message": {
                      "description": "The message returned after submitting an asynchronous task.",
                      "example": "该调用为异步调用，任务已提交成功，请以requestId的值作为jobId参数调用同类目下GetAsyncJobResult接口查询任务执行状态和结果。",
                      "type": "string"
                    },
                    "RequestId": {
                      "description": "The request ID.",
                      "example": "0033B795-09C7-4EB9-A33C-EBA325192B0D",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Shot parsing"
      }
    },
    "/evaluate-video-quality": {
      "post": {
        "description": "This topic describes the syntax and Sample of EvaluateVideoQuality in the Video recognition (videorecog) category. The gateway injects Alibaba RPC Action=EvaluateVideoQuality and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.videorecog.EvaluateVideoQuality",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "Mode": {
                    "description": "Quality assessment pattern. Valid values:  \n- general (default): Basic quality assessment.  \n- vqa_plus: Basic quality assessment and defect quality assessment.",
                    "example": "vqa_plus",
                    "type": "string"
                  },
                  "VideoUrl": {
                    "description": "Video URL. We recommend using an OSS Link in the Shanghai region. For files stored locally or in an OSS bucket outside the Shanghai region, see [File URL Processing](~~155645~~).",
                    "example": "http://public-vigen-video.oss-cn-shanghai.aliyuncs.com/Common/xxx/dont_delete/decaption/123.mp4",
                    "type": "string"
                  }
                },
                "required": [
                  "VideoUrl"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "Schema of Response",
                  "properties": {
                    "Data": {
                      "description": "The returned data content.  \nYou can obtain this data after the asynchronous task execution succeeds by invoking the [GetAsyncJobResult](~~607824~~) API and deserializing the JSON in its Result field.",
                      "properties": {
                        "JsonUrl": {
                          "description": "Detailed quality assessment report (JSON file).  \n\n> This URL is temporary and has a Validity Period of 30 minutes. After expiration, it will no longer be accessible. If you need to retain the file for an extended period or with permanent retention, access the URL and download the file within 30 minutes, then save it to your own OSS bucket or other storage Space.",
                          "example": "http://vibktprfx-prod-prod-damo-eas-cn-shanghai.oss-cn-shanghai.aliyuncs.com/eas-video-quality-assessment/2023-01-13-10/31%3A08-cVeN9ZQlzIPfGqsa.json?Expires=1673578869&amp;OSSAccessKeyId=LTAI****************&amp;Signature=AiSsOsZ7rYfhf9w3Mxn%2Fq4GKKy****",
                          "type": "string"
                        },
                        "PdfUrl": {
                          "description": "Comprehensive quality assessment report (PDF file).  \n\n> This URL is temporary and has a Validity Period of 30 minutes. After expiration, it will no longer be accessible. If you need to retain the file for an extended period or with permanent retention, access the URL and download the file within 30 minutes, then save it to your own OSS bucket or other storage Space.",
                          "example": "http://vibktprfx-prod-prod-damo-eas-cn-shanghai.oss-cn-shanghai.aliyuncs.com/eas-video-quality-assessment/2023-01-13-10/31%3A08-cVeN9ZQlzIPfGqsa.pdf?Expires=1673578869&amp;OSSAccessKeyId=LTAI****************&amp;Signature=xULlZzVuhoYWAXRbp9A4EzzZcS****",
                          "type": "string"
                        },
                        "VideoQualityInfo": {
                          "description": "Video quality details.",
                          "properties": {
                            "Blurriness": {
                              "description": "The degree of blur.",
                              "example": "0.15",
                              "format": "float",
                              "type": "number"
                            },
                            "ColorContrast": {
                              "description": "Contrast.",
                              "example": "0.55",
                              "format": "float",
                              "type": "number"
                            },
                            "ColorSaturation": {
                              "description": "Saturation.",
                              "example": "0.17",
                              "format": "float",
                              "type": "number"
                            },
                            "Colorfulness": {
                              "description": "Colorfulness.",
                              "example": "0.48",
                              "format": "float",
                              "type": "number"
                            },
                            "CompressiveStrength": {
                              "description": "The degree of compression.",
                              "example": "0.25",
                              "format": "float",
                              "type": "number"
                            },
                            "Luminance": {
                              "description": "Luminance.",
                              "example": "0.51",
                              "format": "float",
                              "type": "number"
                            },
                            "MosScore": {
                              "description": "Represents the subjective Quality Score.",
                              "example": "0.7048",
                              "format": "float",
                              "type": "number"
                            },
                            "NoiseIntensity": {
                              "description": "The degree of noise.",
                              "example": "0.01",
                              "format": "float",
                              "type": "number"
                            }
                          },
                          "type": "object"
                        }
                      },
                      "type": "object"
                    },
                    "Message": {
                      "description": "The message returned after committing an asynchronous task.",
                      "example": "该调用为异步调用，任务已提交成功，请以requestId的值作为jobId参数调用同类目下GetAsyncJobResult接口查询任务执行状态和结果。",
                      "type": "string"
                    },
                    "RequestId": {
                      "description": "The request ID.",
                      "example": "1d33e538-c949-4fcd-83f6-4d57e4b31527",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Video Quality Assessment"
      }
    },
    "/generate-video-cover": {
      "post": {
        "description": "This topic describes the syntax and examples of the GenerateVideoCover operation for video thumbnails. The gateway injects Alibaba RPC Action=GenerateVideoCover and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.videorecog.GenerateVideoCover",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "IsGif": {
                    "description": "Specifies whether to output the thumbnail in GIF format. true indicates that the thumbnail is in GIF format; false indicates that it is a standard image.",
                    "example": "false",
                    "type": "boolean"
                  },
                  "VideoUrl": {
                    "description": "The video URL. We recommend using an OSS link from the China (Shanghai) region. For local files or OSS links from other regions, see [File URL Processing](~~155645~~).",
                    "example": "http://viapi-test.oss-cn-shanghai.aliyuncs.com/viapi-3.0domepic/videorecog/videorecog/videorecog1.mp4",
                    "type": "string"
                  }
                },
                "required": [
                  "VideoUrl",
                  "IsGif"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Data": {
                      "description": "The content of the returned result data.  \nThis data is obtained after an asynchronous task execution succeeds, by invoking the [GetAsyncJobResult](~~607824~~) API and performing JSON deserialization on its Result field.",
                      "properties": {
                        "Outputs": {
                          "description": "A list of returned information. Each element is a thumbnail image, and multiple thumbnails may be returned. This field contains data only when the operation succeeds.",
                          "items": {
                            "properties": {
                              "Confidence": {
                                "description": "Confidence level. A higher value indicates higher reliability.",
                                "example": "6.1819260887924425",
                                "format": "float",
                                "type": "number"
                              },
                              "ImageURL": {
                                "description": "The URL of the output thumbnail image.  \n> This URL is temporary, with a validity period of 30 minutes. It will expire and become inaccessible afterward.",
                                "example": "http://algo-app-aic-vd-cn-shanghai-prod.oss-cn-shanghai.aliyuncs.com/video-cover/2020-05-11-07/pic_lOyxGGAqQYSANGxP.mp4_202_544_960_c9f88b2a5f75e17c093d1a65f5edff4d_beautified.png?Expires=1589185385&OSSAccessKeyId=LTAI****************&Signature=PAalKsfeZC4UQzYDTU%2F3D1G7Xt****",
                                "type": "string"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "Message": {
                      "description": "The message returned after submitting the asynchronous task.",
                      "example": "该调用为异步调用，任务已提交成功，请以requestId的值作为jobId参数调用同类目下GetAsyncJobResult接口查询任务执行状态和结果。",
                      "type": "string"
                    },
                    "RequestId": {
                      "description": "The request ID.",
                      "example": "5B95B724-C5B9-4F77-A743-0CA4EA95CC82",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Video Thumbnail"
      }
    },
    "/recognize-video-cast-crew-list": {
      "post": {
        "description": "This topic describes the syntax and examples of the RecognizeVideoCastCrewList video OCR operation. The gateway injects Alibaba RPC Action=RecognizeVideoCastCrewList and Version automatically before forwarding the paid request upstream.",
        "operationId": "alibaba.videorecog.RecognizeVideoCastCrewList",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "properties": {
                  "Params": {
                    "description": "Parameter control for scenario result output features.",
                    "items": {
                      "properties": {
                        "Type": {
                          "description": "Video information extraction type:  \n- subtitles: caption extraction.  \n- cast: cast and crew table extraction.",
                          "example": "cast",
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "type": "array"
                  },
                  "VideoUrl": {
                    "description": "Video URL. We recommend using an OSS link in the China (Shanghai) region. For files stored locally or via an OSS link in a different region, see [File URL Processing](~~155645~~).",
                    "example": "https://shanghai.oss-cn-shanghai.aliyuncs.com/download/xxxx.mp4",
                    "type": "string"
                  }
                },
                "required": [
                  "VideoUrl"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "Schema of Response",
                  "properties": {
                    "Data": {
                      "description": "The returned data content.  \nYou can obtain this data after the asynchronous task execution succeeds by invoking the [GetAsyncJobResult](~~607824~~) API and performing JSON deserialization on its Result field.",
                      "properties": {
                        "CastResults": {
                          "description": "Cast and crew table detection result.",
                          "items": {
                            "description": "Cast and crew table detection result.",
                            "properties": {
                              "DetailInfo": {
                                "additionalProperties": true,
                                "description": "Detailed content.",
                                "type": "object"
                              },
                              "EndTime": {
                                "description": "End UNIX timestamp of the video frames, in seconds.",
                                "example": "0.6",
                                "format": "float",
                                "type": "number"
                              },
                              "StartTime": {
                                "description": "Start UNIX timestamp of the video frames, in seconds.",
                                "example": "0.6",
                                "format": "float",
                                "type": "number"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        },
                        "OcrResults": {
                          "description": "Text detection results at 3 frames per second.",
                          "items": {
                            "properties": {
                              "DetailInfo": {
                                "description": "Detailed content.",
                                "items": {
                                  "properties": {
                                    "Boxes": {
                                      "description": "Coordinates of the rectangular bounding box for the text, in the order [xmin, ymin, xmax, ymax].",
                                      "items": {
                                        "description": "Coordinates of the rectangular bounding box for the text, in the order [xmin, ymin, xmax, ymax].",
                                        "example": "[452,27,505,46]",
                                        "format": "int32",
                                        "type": "integer"
                                      },
                                      "type": "array"
                                    },
                                    "CharProbs": {
                                      "description": "Confidence level for each detected character in the text, with values ranging from 0 to 1.0.",
                                      "items": {
                                        "description": "Confidence level for each detected character in the text, with values ranging from 0 to 1.0.",
                                        "items": {
                                          "description": "Confidence level for each individual character in the text, with values ranging from 0 to 1.0.",
                                          "example": "0.9405716061592102",
                                          "format": "float",
                                          "type": "number"
                                        },
                                        "type": "array"
                                      },
                                      "type": "array"
                                    },
                                    "FrameIndex": {
                                      "description": "Video frame ordinal number.",
                                      "example": "17",
                                      "format": "int64",
                                      "type": "integer"
                                    },
                                    "Position": {
                                      "description": "Coordinates of the rectangle points indicating the text position [top-left, top-right, bottom-right, bottom-left].",
                                      "items": {
                                        "properties": {
                                          "X": {
                                            "description": "Horizontal coordinate, corresponding to the video width. Unit: pixel.",
                                            "example": "266",
                                            "format": "int64",
                                            "type": "integer"
                                          },
                                          "Y": {
                                            "description": "Vertical coordinate, corresponding to the video height. Unit: pixel.",
                                            "example": "440",
                                            "format": "int64",
                                            "type": "integer"
                                          }
                                        },
                                        "type": "object"
                                      },
                                      "type": "array"
                                    },
                                    "Score": {
                                      "description": "The confidence level of the text detection result, with a value range of 0 to 100.  \n\n> Score = 100 × TextProb.",
                                      "example": "92.07685702563117",
                                      "format": "float",
                                      "type": "number"
                                    },
                                    "Text": {
                                      "description": "Text Classification Result.",
                                      "example": "总策划",
                                      "type": "string"
                                    },
                                    "TextProb": {
                                      "description": "The confidence level of the text detection result, with a value range of 0 to 1.0.",
                                      "example": "0.9207685702563116",
                                      "format": "float",
                                      "type": "number"
                                    },
                                    "TimeStamp": {
                                      "description": "UNIX timestamp of the video frame, in seconds.",
                                      "example": "0.28",
                                      "format": "float",
                                      "type": "number"
                                    },
                                    "TrackId": {
                                      "description": "Ordinal number of the assigned trail ID.",
                                      "example": "1",
                                      "format": "int64",
                                      "type": "integer"
                                    }
                                  },
                                  "type": "object"
                                },
                                "type": "array"
                              },
                              "EndTime": {
                                "description": "The end UNIX timestamp of the video frames, in seconds.",
                                "example": "0.28",
                                "format": "float",
                                "type": "number"
                              },
                              "StartTime": {
                                "description": "Start UNIX timestamp of the video frame, in seconds.",
                                "example": "0.28",
                                "format": "float",
                                "type": "number"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        },
                        "OcrResultsUrl": {
                          "description": "Detailed and complete content of the OcrResults, i.e., detection results at 3 frames per second.  \n> This field is deprecated and returns empty.",
                          "example": "http://vibktprfx-prod-prod-media-ai-cn-shanghai.oss-cn-shanghai.aliyuncs.com/video-ocr/1665475907_bGHMygKsFw.json?Expires=1665477707&OSSAccessKeyId=LTAI****************&Signature=6KQb9OXQldsg30w%2FNurHwAbjiJs%3D",
                          "type": "string"
                        },
                        "OcrVideoResultsUrl": {
                          "description": "The detailed and complete content of the OcrVideoResults.  \n> This field is deprecated and returns empty.",
                          "example": "http://vibktprfx-prod-prod-media-ai-cn-shanghai.oss-cn-shanghai.aliyuncs.com/video-ocr/1665475907_VSRvetTHon.json?Expires=1665477707&OSSAccessKeyId=LTAI****************&Signature=wfQviVVSyVRLPVlHDKXi6cTefHY%3D",
                          "type": "string"
                        },
                        "SubtitlesResults": {
                          "description": "Caption detection result.",
                          "items": {
                            "description": "Caption detection result.",
                            "properties": {
                              "SubtitlesAllResults": {
                                "additionalProperties": true,
                                "description": "The complete Classification Result of caption detection in both Chinese and English.",
                                "type": "object"
                              },
                              "SubtitlesAllResultsUrl": {
                                "description": "The download URL of the standard SRT format file corresponding to the caption detection result in both Chinese and English.",
                                "example": "url",
                                "type": "string"
                              },
                              "SubtitlesChineseResults": {
                                "additionalProperties": true,
                                "description": "The Chinese Classification Result of caption detection.",
                                "type": "object"
                              },
                              "SubtitlesChineseResultsUrl": {
                                "description": "The download URL of the standard SRT format file corresponding to the Chinese caption detection result.",
                                "example": "url1",
                                "type": "string"
                              },
                              "SubtitlesEnglishResults": {
                                "additionalProperties": true,
                                "description": "The English Classification Result of caption detection.",
                                "example": "hello",
                                "type": "object"
                              },
                              "SubtitlesEnglishResultsUrl": {
                                "description": "The download URL of the standard SRT format file corresponding to the English caption detection result.",
                                "example": "url2",
                                "type": "string"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        },
                        "VideoOcrResults": {
                          "description": "Text detection results at the video clip level.",
                          "items": {
                            "properties": {
                              "DetailInfo": {
                                "description": "Detailed content.",
                                "items": {
                                  "properties": {
                                    "Boxes": {
                                      "description": "Coordinates of the bounding box for the detected text, in the order [xmin, ymin, xmax, ymax].",
                                      "items": {
                                        "description": "Coordinates of the bounding box for the detected text, in the order [xmin, ymin, xmax, ymax].",
                                        "example": "[266,440,314,476]",
                                        "format": "int64",
                                        "type": "integer"
                                      },
                                      "type": "array"
                                    },
                                    "Position": {
                                      "description": "Coordinates of the rectangle points indicating text position [top-left, top-right, bottom-right, bottom-left].",
                                      "items": {
                                        "properties": {
                                          "X": {
                                            "description": "Horizontal coordinate corresponding to the video width, in pixels.",
                                            "example": "269",
                                            "format": "int64",
                                            "type": "integer"
                                          },
                                          "Y": {
                                            "description": "Vertical coordinate corresponding to the video height, in pixels.",
                                            "example": "423",
                                            "format": "int64",
                                            "type": "integer"
                                          }
                                        },
                                        "type": "object"
                                      },
                                      "type": "array"
                                    },
                                    "Score": {
                                      "description": "Confidence level of the text detection result, with a value range of 0 to 100.",
                                      "example": "92.07685702563117",
                                      "format": "float",
                                      "type": "number"
                                    },
                                    "Text": {
                                      "description": "Text detection result.",
                                      "example": "总顾问",
                                      "type": "string"
                                    },
                                    "TextType": {
                                      "description": "Text type. Valid values:\n\n- 0: Normal caption  \n- 1: Scroll caption  \n- 2: Fixed-length identity caption",
                                      "example": "0",
                                      "format": "int64",
                                      "type": "integer"
                                    }
                                  },
                                  "type": "object"
                                },
                                "type": "array"
                              },
                              "EndTime": {
                                "description": "End UNIX timestamp of the video frames, in seconds.",
                                "example": "0.92",
                                "format": "float",
                                "type": "number"
                              },
                              "StartTime": {
                                "description": "UNIX timestamp of the start time of the video frame, in seconds.",
                                "example": "0.92",
                                "format": "float",
                                "type": "number"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "Message": {
