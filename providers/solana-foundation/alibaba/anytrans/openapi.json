    "/anytrans/translate/batch": {
      "post": {
        "description": "Tongyi Multimodal Batch Translation",
        "operationId": "alibaba.anytrans.BatchTranslate",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "appName": {
                    "description": "Source of the request",
                    "example": "baidufanyi",
                    "type": "string"
                  },
                  "ext": {
                    "description": "Extension parameters that control translation features",
                    "properties": {
                      "config": {
                        "description": "Translation behavior control",
                        "properties": {
                          "skipCsiCheck": {
                            "description": "Whether to skip content safety inspection (CSI). If skipping CSI is required, you must complete the CSI shutdown flow before invoking the translation.",
                            "example": "false",
                            "type": "boolean"
                          }
                        },
                        "type": "object"
                      },
                      "domainHint": {
                        "description": "Domain hint (a piece of natural English text used to guide the LLM on translation style)",
                        "example": "this sentence from an e-commerce product image, please provide a translation that is both highly concise and no more than 1.2 times the length of the original.",
                        "type": "string"
                      },
                      "examples": {
                        "description": "List of translation samples",
                        "items": {
                          "description": "Translation sample",
                          "properties": {
                            "src": {
                              "description": "Source text",
                              "example": "你好",
                              "type": "string"
                            },
                            "tgt": {
                              "description": "Target text",
                              "example": "hello",
                              "type": "string"
                            }
                          },
                          "type": "object"
                        },
                        "type": "array"
                      },
                      "langDetect": {
                        "default": "false",
                        "type": "boolean"
                      },
                      "paramMap": {
                        "description": "Extended parameter configuration (bizUserId: the business-level User ID used to distinguish different business users, enabling \"user-isolated\" terminology intervention without mutual impact. bizType: the business scenario type or identity used to differentiate scenarios, enabling \"scenario-isolated\" terminology intervention without mutual impact.)",
                        "example": "{\"bizUserld\":\"123456\",\"bizType\":session\"}"
                      },
                      "sensitives": {
                        "description": "Sensitive word library",
                        "items": {
                          "description": "Sensitive words to be filtered",
                          "example": "password",
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "terminologies": {
                        "description": "Translation terminology library",
                        "items": {
                          "description": "Term pairs for intervention",
                          "properties": {
                            "src": {
                              "description": "Source text",
                              "example": "应用接口",
                              "type": "string"
                            },
                            "tgt": {
                              "description": "Translated text after intervention",
                              "example": "API",
                              "type": "string"
                            }
                          },
                          "type": "object"
                        },
                        "type": "array"
                      },
                      "textTransform": {
                        "description": "Translated text transformation",
                        "properties": {
                          "toLower": {
                            "description": "Convert the entire translated text to lowercase",
                            "example": "false",
                            "type": "boolean"
                          },
                          "toTitle": {
                            "description": "Convert the entire translated text to capitalized title case",
                            "example": "false",
                            "type": "boolean"
                          },
                          "toUpper": {
                            "description": "Convert the entire translation to uppercase",
                            "example": "false",
                            "type": "boolean"
                          }
                        },
                        "type": "object"
                      }
                    },
                    "type": "object"
                  },
                  "format": {
                    "description": "Translation format",
                    "example": "text",
                    "type": "string"
                  },
                  "scene": {
                    "description": "Translation model",
                    "example": "mt-turbo",
                    "type": "string"
                  },
                  "sourceLanguage": {
                    "description": "Source language",
                    "example": "zh",
                    "type": "string"
                  },
                  "targetLanguage": {
                    "description": "Target language",
                    "example": "en",
                    "type": "string"
                  },
                  "text": {
                    "additionalProperties": true,
                    "description": "Batch text to be translated",
                    "example": "{\"0\":\"明天天气怎么样？\",\"1\":\"你中午吃饭了吗\"}",
                    "type": "object"
                  },
                  "workspaceId": {
                    "description": "The Model Studio workspace ID used for the current request",
                    "example": "llm-kqtrcpdee4xm29xx",
                    "type": "string"
                  }
                },
                "required": [
                  "workspaceId",
                  "sourceLanguage",
                  "targetLanguage",
                  "text"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "Schema of Response",
                  "properties": {
                    "code": {
                      "description": "Response status code",
                      "example": "200",
                      "type": "string"
                    },
                    "data": {
                      "description": "Returned Data",
                      "properties": {
                        "translationList": {
                          "description": "Batch translation results",
                          "items": {
                            "description": "Single translation result",
                            "properties": {
                              "code": {
                                "description": "Response status code",
                                "example": "200",
                                "format": "int64",
                                "type": "integer"
                              },
                              "detectedLang": {
                                "description": "Language detection result, returned only when the source language in the request parameter is set to auto, in the format {language code}:{confidence level}",
                                "type": "string"
                              },
                              "index": {
                                "description": "Index of a single translation result",
                                "example": "0",
                                "type": "string"
                              },
                              "message": {
                                "description": "Response message",
                                "example": "OK",
                                "type": "string"
                              },
                              "translation": {
                                "description": "Translation result corresponding to this index",
                                "example": "What will the weather be like tomorrow?",
                                "type": "string"
                              },
                              "usage": {
                                "description": "Token usage",
                                "properties": {
                                  "inputTokens": {
                                    "description": "Number of input tokens",
                                    "example": "53",
                                    "format": "int64",
                                    "type": "integer"
                                  },
                                  "outputTokens": {
                                    "description": "Number of output tokens",
                                    "example": "8",
                                    "format": "int64",
                                    "type": "integer"
                                  },
                                  "totalTokens": {
                                    "description": "Total number of tokens",
                                    "example": "61",
                                    "format": "int64",
                                    "type": "integer"
                                  }
                                },
                                "type": "object"
                              }
                            },
                            "type": "object"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "httpStatusCode": {
                      "description": "HTTP status code",
                      "example": "200",
                      "type": "string"
                    },
                    "message": {
                      "description": "Response message",
                      "example": "success",
                      "type": "string"
                    },
                    "requestId": {
                      "description": "Request ID, used to trace the API call chain",
                      "example": "3BE338D3-16B1-513F-8DD2-57C8528DEAAA",
                      "type": "string"
                    },
                    "success": {
                      "default": "true",
                      "description": "Indicates whether the API call succeeded",
                      "example": "true",
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Batch Text Translation"
      }
    },
