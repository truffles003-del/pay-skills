{
  "info": {
    "description": "Filtered OpenAPI description for the stateless synchronous Alibaba Cloud Agent Skills Explorer proxy. The gateway serves only the allowlisted operations defined in the paired YAML manifest.",
    "title": "Alibaba Cloud Agent Skills Explorer API",
    "version": "2026-03-17"
  },
  "openapi": "3.0.3",
  "paths": {
    "/openapi/categories": {
      "get": {
        "description": "List all Alibaba Cloud Skills categories.",
        "operationId": "alibaba.agentexplorer.ListCategories",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "Schema of Response",
                  "properties": {
                    "data": {
                      "description": "The returned category list",
                      "items": {
                        "additionalProperties": true,
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "message": {
                      "description": "Response message",
                      "example": "success",
                      "type": "string"
                    },
                    "requestId": {
                      "description": "request ID",
                      "example": "099A671E-FA21-5A36-8A73-918572DDEF53",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Obtain information about all Agent Skills categories"
      }
    },
    "/openapi/skills": {
      "get": {
        "description": "Search Alibaba Cloud Agent Skills by keyword or category.",
        "operationId": "alibaba.agentexplorer.SearchSkills",
        "parameters": [
          {
            "description": "search keyword",
            "in": "query",
            "name": "keyword",
            "required": false,
            "schema": {
              "description": "search keyword",
              "example": "ecs",
              "type": "string"
            }
          },
          {
            "description": "Skill category code. If multiple codes are provided, separate them with commas. For a second-level category, specify it as \"first-level-category.second-level-category\".",
            "in": "query",
            "name": "categoryCode",
            "required": false,
            "schema": {
              "description": "Skill category code. If multiple codes are provided, separate them with commas. For a second-level category, specify it as \"first-level-category.second-level-category\".",
              "example": "compute.serverless,network",
              "type": "string"
            }
          },
          {
            "description": "The token to start the next query from, using the NextToken parameter value returned by the previous API call",
            "in": "query",
            "name": "nextToken",
            "required": false,
            "schema": {
              "description": "The token to start the next query from, using the NextToken parameter value returned by the previous API call",
              "example": "AAAAAZjtYxxxxxxxx",
              "type": "string"
            }
          },
          {
            "description": "The maximum number of entries per page for paged queries. The maximum value is 100. The default value is 20.",
            "in": "query",
            "name": "maxResults",
            "required": false,
            "schema": {
              "description": "The maximum number of entries per page for paged queries. The maximum value is 100. The default value is 20.",
              "example": "20",
              "format": "int32",
              "type": "integer"
            }
          },
          {
            "description": "Pagination parameter indicating the number of records to skip",
            "in": "query",
            "name": "skip",
            "required": false,
            "schema": {
              "description": "Pagination parameter indicating the number of records to skip",
              "example": "10",
              "format": "int32",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "Schema of Response",
                  "properties": {
                    "data": {
                      "description": "The returned list of Skills",
                      "items": {
                        "additionalProperties": true,
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "maxResults": {
                      "description": "The maximum number of entries per page for paged queries. The maximum value is 100. The default value is 20.",
                      "example": "20",
                      "format": "int32",
                      "type": "integer"
                    },
                    "nextToken": {
                      "description": "The returned NextToken, used to retrieve more results.",
                      "example": "AAAAAZjtYxxxxxxxx",
                      "type": "string"
                    },
                    "requestId": {
                      "description": "Id of the request",
                      "example": "53EAEBC0-4DEC-5AF4-AA21-3923D5A819C3",
                      "type": "string"
                    },
                    "totalCount": {
                      "description": "Total number of data records.",
                      "example": "22",
                      "format": "int32",
                      "type": "integer"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Search Alibaba Cloud Agent Skills"
      }
    },
    "/openapi/skills/{skillName}": {
      "get": {
        "description": "Retrieve the content of the SKILL.md file for the specified Agent Skill",
        "operationId": "alibaba.agentexplorer.GetSkillContent",
        "parameters": [
          {
            "description": "skill name",
            "in": "path",
            "name": "skillName",
            "required": true,
            "schema": {
              "description": "skill name",
              "example": "ecs-manager",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "description": "Schema of Response",
                  "properties": {
                    "content": {
                      "description": "Content of the SKILL.md file",
                      "example": "---\nname: alibabacloud-find-skills\ndescription: \"Search for official Alibaba Cloud Agent Skills based on user requirements\"\n---\n\nAgent Skill Body Content Here",
                      "type": "string"
                    },
                    "requestId": {
                      "description": "Id of the request",
                      "example": "1764D64D-5262-55DA-BDBF-1F949B1B34F7",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "Code": {
                      "type": "string"
                    },
                    "Message": {
                      "type": "string"
                    },
                    "RequestId": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Invalid request."
          }
        },
        "summary": "Retrieve the content of the Agent Skill file"
      }
    }
  },
  "servers": [
    {
      "url": "https://agentexplorer.alibaba.gateway-402.com"
    }
  ]
}
